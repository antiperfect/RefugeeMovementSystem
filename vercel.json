{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/flask/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/unhcr/(.*)",
      "destination": "https://api.unhcr.org/population/v1/$1"
    },
    {
      "source": "/api/gdelt/(.*)",
      "destination": "https://api.gdeltproject.org/$1"
    },
    {
      "source": "/api/reliefweb/(.*)",
      "destination": "https://api.reliefweb.int/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/$1"
    }
  ]
}
